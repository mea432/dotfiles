sketchybar --update

FOCUSED_WORKSPACE=$(aerospace list-workspaces --focused 2>/dev/null)
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$FOCUSED_WORKSPACE"
sketchybar --trigger aerospace_mode_change
